#!/usr/bin/env php
<?php

/**
 * @file
 * Export database.
 *
 * This is a router script to call relevant scripts based on type.
 *
 * IMPORTANT! This script runs on the host or inside the container, routing the
 * work to the appropriate location.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Name of the database container image to use.
$db_image = getenv_default('VORTEX_EXPORT_DB_IMAGE', 'VORTEX_DB_IMAGE', '');

// -----------------------------------------------------------------------------

INFO('Started database export.');

if (run_on_host()) {
  if ($db_image === '') {
    // Export database as a file.
    // Script runs inside the container - use path relative to project root.
    $script_rel = ltrim(str_replace((string) getcwd(), '', __DIR__), '/');

    TASK('Exporting database as a file inside the container.', 'Exported database as a file inside the container.', function () use ($script_rel, $argv): void {
      passthru_or_fail('docker compose exec -T cli php ' . $script_rel . '/vortex-export-db-file ' . implode(' ', array_map('escapeshellarg', array_slice($argv, 1))), 'Failed to export database as file.');
    });
  }
  else {
    // Export database as a container image.
    putenv('VORTEX_EXPORT_DB_IMAGE=' . $db_image);

    TASK('Exporting database as a container image.', 'Exported database as a container image.', function () use ($argv): void {
      passthru_or_fail(__DIR__ . '/vortex-export-db-image ' . implode(' ', array_map('escapeshellarg', array_slice($argv, 1))), 'Failed to export database as image.');
    });
  }
}
else {
  // Script already runs inside the container - export the database as a file
  // directly, without dispatching through Docker.
  TASK('Exporting database as a file.', 'Exported database as a file.', function () use ($argv): void {
    passthru_or_fail(__DIR__ . '/vortex-export-db-file ' . implode(' ', array_map('escapeshellarg', array_slice($argv, 1))), 'Failed to export database as file.');
  });
}

PASS('Finished database export.');
