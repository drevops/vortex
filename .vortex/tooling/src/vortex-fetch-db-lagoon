#!/usr/bin/env php
<?php

/**
 * @file
 * Download the latest database backup from a Lagoon environment.
 *
 * Wraps the provider-native 'lagoon' CLI: it lists the environment's scheduled
 * backups, retrieves the latest database snapshot, waits for the asynchronous
 * restore to complete and downloads the resulting dump. Because it relies on
 * the CLI rather than a bespoke SSH + Drush dump, it runs both on a developer
 * host and inside the hosting environment (where the CLI ships with the
 * container image), enabling a non-production environment to pull the
 * production database in-place.
 *
 * The retrieved artifact is the latest scheduled snapshot, so it can be up to
 * as old as the environment's backup schedule (nightly by default). The Lagoon
 * CLI has no primitive to create an on-demand snapshot.
 *
 * A Lagoon backup is delivered as a gzipped tar containing a single database
 * dump, which is extracted to the target file after download.
 *
 * The Lagoon CLI must be available: install it on the host or use a container
 * image that provides it. Authentication uses the SSH key on a host; set
 * 'VORTEX_FETCH_DB_SSH_FILE' to 'false' to rely on the ambient Lagoon identity
 * inside the hosting environment.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Database index suffix.
$db_index = getenv_default('VORTEX_DB_INDEX', '');

// Lagoon project name.
$lagoon_project = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_PROJECT', 'VORTEX_FETCH_DB_LAGOON_PROJECT', 'LAGOON_PROJECT'])));

// The source environment to download the database from.
$environment = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_ENVIRONMENT', 'VORTEX_FETCH_DB_ENVIRONMENT', 'main'])));

// The Lagoon instance name to interact with.
$instance = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_INSTANCE', 'VORTEX_FETCH_DB_LAGOON_INSTANCE', 'amazeeio'])));

// The Lagoon instance GraphQL endpoint to interact with.
$instance_graphql = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_INSTANCE_GRAPHQL', 'VORTEX_FETCH_DB_LAGOON_INSTANCE_GRAPHQL', 'https://api.lagoon.amazeeio.cloud/graphql'])));

// The SSH host of the Lagoon instance.
$ssh_host = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_SSH_HOST', 'VORTEX_FETCH_DB_LAGOON_SSH_HOST', 'ssh.lagoon.amazeeio.cloud'])));

// The SSH port of the Lagoon instance.
$ssh_port = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_SSH_PORT', 'VORTEX_FETCH_DB_LAGOON_SSH_PORT', '32222'])));

// SSH key file used to authenticate the CLI. Set to 'false' to rely on the
// ambient Lagoon identity (e.g. inside the hosting environment).
$ssh_file = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_SSH_FILE', 'VORTEX_FETCH_DB_SSH_FILE', getenv('HOME') . '/.ssh/id_rsa'])));

// Backup source to select among the environment's backups. This is the name of
// the backed-up service - Vortex names its database service "database".
$backup_source = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_BACKUP_SOURCE', 'VORTEX_FETCH_DB_LAGOON_BACKUP_SOURCE', 'database'])));

// Number of status retrieval retries while waiting for the restore.
$status_retries = (int) getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_STATUS_RETRIES', 'VORTEX_FETCH_DB_LAGOON_STATUS_RETRIES', '600'])));

// Interval in seconds between restore status checks.
$status_interval = (int) getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_STATUS_INTERVAL', 'VORTEX_FETCH_DB_LAGOON_STATUS_INTERVAL', '10'])));

// Timeout in seconds for the backup download. A large production dump over a
// slow link can exceed the default, so it is tunable independently.
$download_timeout = (int) getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_DOWNLOAD_TIMEOUT', 'VORTEX_FETCH_DB_LAGOON_DOWNLOAD_TIMEOUT', '600'])));

// Directory where DB dumps are stored on the host.
$db_dir = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_DB_DIR', 'VORTEX_FETCH_DB' . $db_index . '_DIR', 'VORTEX_DB' . $db_index . '_DIR', 'VORTEX_FETCH_DB_LAGOON_DB_DIR', 'VORTEX_FETCH_DB_DIR', 'VORTEX_DB_DIR', './.data'])));

// Database dump file name on the host.
$db_file = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_LAGOON_DB_FILE', 'VORTEX_FETCH_DB' . $db_index . '_FILE', 'VORTEX_DB' . $db_index . '_FILE', 'VORTEX_FETCH_DB_LAGOON_DB_FILE', 'VORTEX_FETCH_DB_FILE', 'VORTEX_DB_FILE', 'db.sql'])));

// -----------------------------------------------------------------------------

/**
 * Extract a downloaded Lagoon backup artifact in place.
 *
 * Lagoon delivers a k8up backup as a gzipped tar containing a single database
 * dump. When the downloaded file is gzip-compressed, its contents are extracted
 * back into the same path; a file that is not compressed is left untouched.
 *
 * @param string $file
 *   Path to the downloaded artifact, replaced in place with the dump.
 */
function lagoon_extract_backup(string $file): void {
  if (!is_readable($file) || file_get_contents($file, FALSE, NULL, 0, 2) !== "\x1f\x8b") {
    return;
  }

  task('Extracting the database backup.');
  command_must_exist('tar');

  $archive = $file . '.tar.gz';
  rename($file, $archive);
  passthru_or_fail(sprintf('tar -xzOf %s > %s', escapeshellarg($archive), escapeshellarg($file)), 'Failed to extract the database backup.');
  unlink($archive);
}

info('Started database backup download from Lagoon.');

$bin = lagoon_cli_resolve();

// Authenticate the CLI. On a host the SSH key is loaded and passed to the CLI;
// inside the hosting environment ('false') the ambient identity is used.
if ($ssh_file !== 'false') {
  putenv('VORTEX_SSH_PREFIX=FETCH_DB');
  passthru_or_fail(__DIR__ . '/vortex-setup-ssh', 'Failed to setup SSH.');
}

$config_file = lagoon_config_file();

task('Configuring Lagoon instance.');
lagoon_config($bin, $config_file, $instance, $instance_graphql, $ssh_host, $ssh_port);

$ctx = [
  'instance' => $instance,
  'project' => $lagoon_project,
  'config_file' => $config_file,
  'ssh_key' => $ssh_file,
];

// Surface the CLI version and authenticated identity so the run is observable.
task('Lagoon CLI version.');
passthru(sprintf('%s --config-file %s --version 2>&1', escapeshellarg($bin), escapeshellarg($config_file)));
task('Lagoon authenticated identity.');
echo lagoon_exec($bin, 'whoami', $ctx);

if (!is_dir($db_dir)) {
  task('Creating directory for database dumps.');
  mkdir($db_dir, 0755, TRUE);
}

task(sprintf('Discovering "%s" backups for environment "%s".', $backup_source, $environment));
$json = lagoon_exec($bin, sprintf('list backups --environment %s --output-json --pretty', escapeshellarg($environment)), $ctx);

$data = json_decode($json, TRUE);
$backups = (is_array($data) && isset($data['data']) && is_array($data['data'])) ? $data['data'] : [];

$candidates = array_filter($backups, fn($backup): bool => is_array($backup) && ($backup['source'] ?? '') === $backup_source);

if (count($candidates) === 0) {
  fail('No "%s" backups found for environment "%s".', $backup_source, $environment);
}

// Pick the most recent backup by creation timestamp.
usort($candidates, fn($a, $b): int => strcmp((string) ($b['created'] ?? ''), (string) ($a['created'] ?? '')));
$backup = reset($candidates);
$backup_id = (string) ($backup['backupid'] ?? '');

if ($backup_id === '') {
  fail('Unable to determine the latest backup ID.');
}

note(sprintf('Selected backup "%s" created at "%s".', $backup_id, (string) ($backup['created'] ?? 'unknown')));

// Trigger the asynchronous restore. A retrieval that is already in progress is
// not an error - proceed to poll for its completion.
task('Requesting backup retrieval.');
$retrieve_code = 0;
$retrieve_output = lagoon_exec($bin, sprintf('retrieve backup --environment %s --backup-id %s', escapeshellarg($environment), escapeshellarg($backup_id)), $ctx, $retrieve_code);
if ($retrieve_code !== 0 && stripos($retrieve_output, 'already been created') === FALSE) {
  fail('Failed to request backup retrieval: %s', $retrieve_output);
}

task('Waiting for the backup to be retrieved.');
$download_url = '';
for ($i = 1; $i <= $status_retries; $i++) {
  $get_code = 0;
  $get_output = lagoon_exec($bin, sprintf('get backup --environment %s --backup-id %s --output-json', escapeshellarg($environment), escapeshellarg($backup_id)), $ctx, $get_code);

  // The CLI returns the signed URL once the restore is ready and exits with a
  // non-zero code while it is still pending. Extract the URL from either the
  // JSON result or plain output.
  if ($get_code === 0 && preg_match('#https?://[^\s"\\\\]+#', $get_output, $matches) === 1) {
    $download_url = $matches[0];
    break;
  }

  sleep($status_interval);
}

if ($download_url === '') {
  fail('Timed out waiting for the backup to be retrieved.');
}

task('Downloading the database backup.');
$dest = $db_dir . '/' . $db_file;
$response = request($download_url, ['method' => 'GET', 'save_to' => $dest, 'timeout' => $download_timeout]);
if (!$response['ok']) {
  @unlink($dest);
  fail('Failed to download the database backup from Lagoon: %s', $response['error'] ?? 'Unknown error');
}

lagoon_extract_backup($dest);

pass('Finished database backup download from Lagoon.');
