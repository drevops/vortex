#!/usr/bin/env php
<?php

/**
 * @file
 * Download DB dump from S3.
 *
 * Uses AWS Signature Version 4 with curl (no AWS CLI required).
 *
 * IMPORTANT! This script runs outside the container on the host system.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Database index suffix.
$db_index = getenv_default('VORTEX_DB_INDEX', '');

// AWS access key.
$access_key = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_ACCESS_KEY', 'VORTEX_FETCH_DB_S3_ACCESS_KEY', 'S3_ACCESS_KEY'])));

// AWS secret key.
$secret_key = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_SECRET_KEY', 'VORTEX_FETCH_DB_S3_SECRET_KEY', 'S3_SECRET_KEY'])));

// S3 bucket name.
$bucket = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_BUCKET', 'VORTEX_FETCH_DB_S3_BUCKET', 'S3_BUCKET'])));

// S3 region.
$region = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_REGION', 'VORTEX_FETCH_DB_S3_REGION', 'S3_REGION'])));

// S3 prefix (path within the bucket).
$prefix = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_PREFIX', 'VORTEX_FETCH_DB_S3_PREFIX', 'S3_PREFIX', ''])));

// Directory with database dump file.
$db_dir = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_DB_DIR', 'VORTEX_FETCH_DB' . $db_index . '_DIR', 'VORTEX_DB' . $db_index . '_DIR', 'VORTEX_FETCH_DB_S3_DB_DIR', 'VORTEX_FETCH_DB_DIR', 'VORTEX_DB_DIR', './.data'])));

// Database dump file name.
$db_file = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_S3_DB_FILE', 'VORTEX_FETCH_DB' . $db_index . '_FILE', 'VORTEX_DB' . $db_index . '_FILE', 'VORTEX_FETCH_DB_S3_DB_FILE', 'VORTEX_FETCH_DB_FILE', 'VORTEX_DB_FILE', 'db.sql'])));

// -----------------------------------------------------------------------------

INFO('Started database dump download from S3.');

// Ensure prefix ends with a trailing slash if non-empty.
if ($prefix !== '') {
  $prefix = rtrim($prefix, '/') . '/';
}

prepare_db_dir($db_dir);

$uri = sprintf('/%s%s', $prefix, $db_file);
$object_url = sprintf('https://%s.s3.%s.amazonaws.com%s', $bucket, $region, $uri);

NOTE('Remote file: %s%s', $prefix, $db_file);
NOTE('Local path:  %s/%s', $db_dir, $db_file);
NOTE('S3 bucket:   %s', $bucket);
NOTE('S3 region:   %s', $region);
if ($prefix !== '') {
  NOTE('S3 prefix:   %s', $prefix);
}

TASK('Downloading the database dump from S3.', 'Downloaded the database dump from S3.', function () use ($object_url, $bucket, $region, $uri, $access_key, $secret_key, $db_dir, $db_file): void {
  $headers = aws_s3_signed_headers('GET', $bucket, $region, $uri, hash('sha256', ''), $access_key, $secret_key);

  $response = request($object_url, ['method' => 'GET', 'headers' => $headers, 'save_to' => $db_dir . '/' . $db_file, 'timeout' => 300]);

  if (!$response['ok']) {
    throw new \RuntimeException('Failed to download database dump from S3.');
  }
});

PASS('Finished database dump download from S3.');
