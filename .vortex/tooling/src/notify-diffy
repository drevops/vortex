#!/usr/bin/env bash
##
# Notification dispatch to Diffy for visual regression testing.
#
# Triggers the 'test-vr.yml' GitHub Actions workflow via the GitHub
# 'repository_dispatch' API. The workflow then runs the actual Diffy
# comparison and posts the result back to the PR (when applicable).
#
# This script does NOT call the Diffy API directly. It only dispatches
# a GitHub Actions workflow with a payload that the workflow consumes.
#
# shellcheck disable=SC1090,SC1091

t=$(mktemp) && export -p >"${t}" && set -a && . ./.env && if [ -f ./.env.local ]; then . ./.env.local; fi && set +a && . "${t}" && rm "${t}" && unset t

set -eu
[ "${VORTEX_DEBUG-}" = "1" ] && set -x

# Diffy notification GitHub token. Needs 'repo' scope to call the
# 'repository_dispatch' API endpoint. Defaults to the GitHub notification
# token if set, otherwise to GITHUB_TOKEN.
VORTEX_NOTIFY_DIFFY_TOKEN="${VORTEX_NOTIFY_DIFFY_TOKEN:-${VORTEX_NOTIFY_GITHUB_TOKEN:-${GITHUB_TOKEN-}}}"

# Diffy notification GitHub repository in owner/repo format. Defaults
# to the GitHub notification repository.
VORTEX_NOTIFY_DIFFY_REPOSITORY="${VORTEX_NOTIFY_DIFFY_REPOSITORY:-${VORTEX_NOTIFY_GITHUB_REPOSITORY:-}}"

# Diffy notification git branch name.
VORTEX_NOTIFY_DIFFY_BRANCH="${VORTEX_NOTIFY_DIFFY_BRANCH:-${VORTEX_NOTIFY_BRANCH:-}}"

# Diffy notification git commit SHA. The workflow uses this to look up
# the associated pull request via the GitHub API - hosts do not need to
# expose PR numbers themselves.
VORTEX_NOTIFY_DIFFY_SHA="${VORTEX_NOTIFY_DIFFY_SHA:-${VORTEX_NOTIFY_SHA:-}}"

# Diffy notification target environment URL. The deployed environment
# that should be compared against the Diffy source environment.
VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL="${VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL:-${VORTEX_NOTIFY_ENVIRONMENT_URL:-}}"

# Diffy notification deployment label. Used as the diff name visible
# in the Diffy UI.
VORTEX_NOTIFY_DIFFY_LABEL="${VORTEX_NOTIFY_DIFFY_LABEL:-${VORTEX_NOTIFY_LABEL:-}}"

# Diffy notification event type. Can be 'pre_deployment' or 'post_deployment'.
VORTEX_NOTIFY_DIFFY_EVENT="${VORTEX_NOTIFY_DIFFY_EVENT:-${VORTEX_NOTIFY_EVENT:-}}"

# Diffy notification source environment name. The Diffy environment
# (production, staging, development) to use as the baseline. Diffy
# resolves the URL from its own project configuration.
VORTEX_NOTIFY_DIFFY_SOURCE_ENV="${VORTEX_NOTIFY_DIFFY_SOURCE_ENV:-production}"

# Diffy notification dispatch event type. The GitHub Actions
# 'repository_dispatch' event type that the test-vr.yml workflow listens
# for. Override only if the workflow has been renamed.
VORTEX_NOTIFY_DIFFY_EVENT_TYPE="${VORTEX_NOTIFY_DIFFY_EVENT_TYPE:-vr_run}"

# Diffy notification branch filter.
#
# Comma-separated list of branch names. When set, the dispatch is only
# sent for deployments on the listed branches. When empty (default),
# every deployment is dispatched - the workflow then decides whether to
# run based on whether the deployed SHA has an open PR with the
# configured label.
VORTEX_NOTIFY_DIFFY_BRANCHES="${VORTEX_NOTIFY_DIFFY_BRANCHES:-}"

# ------------------------------------------------------------------------------

# @formatter:off
info() { [ "${TERM:-}" != "dumb" ] && tput colors >/dev/null 2>&1 && printf "\033[36m[INFO] %s\033[0m\n" "${1}" || printf "[INFO] %s\n" "${1}"; }
note() { printf "       %s\n" "${1}"; }
task() { _TASK_START=$(date +%s); [ "${TERM:-}" != "dumb" ] && tput colors >/dev/null 2>&1 && printf "\033[34m[TASK] %s\033[0m\n" "${1}" || printf "[TASK] %s\n" "${1}"; }
pass() { _d=""; [ -n "${_TASK_START:-}" ] && _d=" ($(($(date +%s) - _TASK_START))s)" && unset _TASK_START; [ "${TERM:-}" != "dumb" ] && tput colors >/dev/null 2>&1 && printf "\033[32m[ OK ] %s%s\033[0m\n" "${1}" "${_d}" || printf "[ OK ] %s%s\n" "${1}" "${_d}"; }
fail() { [ "${TERM:-}" != "dumb" ] && tput colors >/dev/null 2>&1 && printf "\033[31m[FAIL] %s\033[0m\n" "${1}" || printf "[FAIL] %s\n" "${1}"; }
# @formatter:on

#shellcheck disable=SC2043
for cmd in curl; do command -v "${cmd}" >/dev/null || {
  fail "Command ${cmd} is not available"
  exit 1
}; done

info "Started Diffy notification."

# Skip on pre_deployment - the target environment is not yet ready.
if [ "${VORTEX_NOTIFY_DIFFY_EVENT}" = "pre_deployment" ]; then
  pass "Skipping Diffy notification for pre_deployment event."
  exit 0
fi

# Apply branch filter when configured. When empty (default), every
# deployment is dispatched and the workflow gates on PR + label.
if [ -n "${VORTEX_NOTIFY_DIFFY_BRANCHES}" ]; then
  if ! echo ",${VORTEX_NOTIFY_DIFFY_BRANCHES}," | grep -qF ",${VORTEX_NOTIFY_DIFFY_BRANCH},"; then
    pass "Skipping Diffy notification for branch '${VORTEX_NOTIFY_DIFFY_BRANCH}' (not in branch allowlist)."
    exit 0
  fi
fi

# Validate required values.
[ -z "${VORTEX_NOTIFY_DIFFY_TOKEN}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_TOKEN" && exit 1
[ -z "${VORTEX_NOTIFY_DIFFY_REPOSITORY}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_REPOSITORY" && exit 1
[ -z "${VORTEX_NOTIFY_DIFFY_BRANCH}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_BRANCH" && exit 1
[ -z "${VORTEX_NOTIFY_DIFFY_SHA}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_SHA" && exit 1
[ -z "${VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL" && exit 1
[ -z "${VORTEX_NOTIFY_DIFFY_LABEL}" ] && fail "Missing required value for VORTEX_NOTIFY_DIFFY_LABEL" && exit 1

# Sanitize repository (extract owner/repo, hide host if any).
repository_sanitized=$(echo "${VORTEX_NOTIFY_DIFFY_REPOSITORY}" | sed -E 's|^https?://[^/]+/||; s|\.git$||')

info "Diffy notification summary:"
note "Repository       : ${repository_sanitized}"
note "Branch           : ${VORTEX_NOTIFY_DIFFY_BRANCH}"
note "SHA              : ${VORTEX_NOTIFY_DIFFY_SHA}"
note "Label            : ${VORTEX_NOTIFY_DIFFY_LABEL}"
note "Environment URL  : ${VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL}"
note "Source env       : ${VORTEX_NOTIFY_DIFFY_SOURCE_ENV}"
note "Dispatch event   : ${VORTEX_NOTIFY_DIFFY_EVENT_TYPE}"
note "Event            : ${VORTEX_NOTIFY_DIFFY_EVENT}"

# Build dispatch payload. All values JSON-escaped via a single PHP call.
# The workflow derives the PR (if any) from the SHA via the GitHub API,
# so we do not include a PR number in the payload.
payload=$(
  VORTEX_NOTIFY_DIFFY_EVENT_TYPE="${VORTEX_NOTIFY_DIFFY_EVENT_TYPE}" \
  VORTEX_NOTIFY_DIFFY_SHA="${VORTEX_NOTIFY_DIFFY_SHA}" \
  VORTEX_NOTIFY_DIFFY_BRANCH="${VORTEX_NOTIFY_DIFFY_BRANCH}" \
  VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL="${VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL}" \
  VORTEX_NOTIFY_DIFFY_LABEL="${VORTEX_NOTIFY_DIFFY_LABEL}" \
  VORTEX_NOTIFY_DIFFY_SOURCE_ENV="${VORTEX_NOTIFY_DIFFY_SOURCE_ENV}" \
  php -r '
    echo json_encode([
      "event_type" => getenv("VORTEX_NOTIFY_DIFFY_EVENT_TYPE"),
      "client_payload" => [
        "sha" => getenv("VORTEX_NOTIFY_DIFFY_SHA"),
        "branch" => getenv("VORTEX_NOTIFY_DIFFY_BRANCH"),
        "target_url" => getenv("VORTEX_NOTIFY_DIFFY_ENVIRONMENT_URL"),
        "label" => getenv("VORTEX_NOTIFY_DIFFY_LABEL"),
        "source_env" => getenv("VORTEX_NOTIFY_DIFFY_SOURCE_ENV"),
      ],
    ]);
  '
)

response_code=$(curl \
  -X POST \
  -H "Accept: application/vnd.github.v3+json" \
  -H "Authorization: token ${VORTEX_NOTIFY_DIFFY_TOKEN}" \
  -H "Content-Type: application/json" \
  -s -o /dev/null -w "%{http_code}" \
  "https://api.github.com/repos/${repository_sanitized}/dispatches" \
  -d "${payload}")

if [ "${response_code}" != "204" ]; then
  fail "GitHub repository_dispatch failed with HTTP ${response_code}."
  exit 1
fi

pass "Finished Diffy notification."
