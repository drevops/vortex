#!/usr/bin/env php
<?php

/**
 * @file
 * Push DB dump to S3.
 *
 * Uses AWS Signature Version 4 with curl (no AWS CLI required).
 *
 * IMPORTANT! This script runs outside the container on the host system.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// AWS access key.
$access_key = getenv_required('VORTEX_PUSH_DB_S3_ACCESS_KEY', 'S3_ACCESS_KEY');

// AWS secret key.
$secret_key = getenv_required('VORTEX_PUSH_DB_S3_SECRET_KEY', 'S3_SECRET_KEY');

// S3 bucket name.
$bucket = getenv_required('VORTEX_PUSH_DB_S3_BUCKET', 'S3_BUCKET');

// S3 region.
$region = getenv_required('VORTEX_PUSH_DB_S3_REGION', 'S3_REGION');

// S3 prefix (path within the bucket).
$prefix = getenv_default('VORTEX_PUSH_DB_S3_PREFIX', 'S3_PREFIX', '');

// Directory with database dump file.
$db_dir = getenv_default('VORTEX_PUSH_DB_S3_DB_DIR', 'VORTEX_DB_DIR', './.data');

// Database dump file name.
$db_file = getenv_default('VORTEX_PUSH_DB_S3_DB_FILE', 'VORTEX_DB_FILE', 'db.sql');

// Remote database dump file name.
$remote_file = getenv_default('VORTEX_PUSH_DB_S3_REMOTE_FILE', 'db.sql');

// S3 storage class.
$storage_class = getenv_default('VORTEX_PUSH_DB_S3_STORAGE_CLASS', 'STANDARD');

// -----------------------------------------------------------------------------

$local_file = $db_dir . '/' . $db_file;
if (!file_exists($local_file)) {
  FAIL('Database dump file %s does not exist.', $local_file);
}

INFO('Started database dump push to S3.');

// Ensure prefix ends with a trailing slash if non-empty.
if ($prefix !== '') {
  $prefix = rtrim($prefix, '/') . '/';
}

$uri = sprintf('/%s%s', $prefix, $remote_file);
$object_url = sprintf('https://%s.s3.%s.amazonaws.com%s', $bucket, $region, $uri);

NOTE('Local file:     %s', $local_file);
NOTE('Remote file:    %s%s', $prefix, $remote_file);
NOTE('S3 bucket:      %s', $bucket);
NOTE('S3 region:      %s', $region);
if ($prefix !== '') {
  NOTE('S3 prefix:      %s', $prefix);
}
NOTE('Storage class:  %s', $storage_class);

TASK('Pushing the database dump to S3.', 'Pushed the database dump to S3.', function () use ($object_url, $bucket, $region, $uri, $access_key, $secret_key, $storage_class, $local_file): void {
  $headers = aws_s3_signed_headers('PUT', $bucket, $region, $uri, (string) hash_file('sha256', $local_file), $access_key, $secret_key, ['x-amz-server-side-encryption' => 'AES256', 'x-amz-storage-class' => $storage_class]);

  $response = request($object_url, ['method' => 'PUT', 'headers' => $headers, 'upload_file' => $local_file, 'timeout' => 600]);

  if (!$response['ok']) {
    throw new \RuntimeException('Failed to push database dump to S3.');
  }
});

PASS('Finished database dump push to S3.');
