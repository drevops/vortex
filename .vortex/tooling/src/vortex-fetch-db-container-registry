#!/usr/bin/env php
<?php

/**
 * @file
 * Download DB dump from container image.
 *
 * IMPORTANT! This script runs outside the container on the host system.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Database index suffix.
$db_index = getenv_default('VORTEX_DB_INDEX', '');

// The container image containing database in a form of `<org>/<repository>`.
$image = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY_IMAGE', 'VORTEX_DB' . $db_index . '_IMAGE', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY_IMAGE', 'VORTEX_DB_IMAGE'])));

// Container registry name.
//
// Provide port, if required as `<server_name>:<port>`.
$registry = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY', 'VORTEX_CONTAINER_REGISTRY', 'docker.io'])));

// The username to login into the container registry.
$registry_user = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY_USER', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY_USER', 'VORTEX_CONTAINER_REGISTRY_USER'])));

// The password to login into the container registry.
$registry_pass = getenv_required(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY_PASS', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY_PASS', 'VORTEX_CONTAINER_REGISTRY_PASS'])));

// Directory with database dump file.
$db_dir = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY_DB_DIR', 'VORTEX_FETCH_DB' . $db_index . '_DIR', 'VORTEX_DB' . $db_index . '_DIR', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY_DB_DIR', 'VORTEX_FETCH_DB_DIR', 'VORTEX_DB_DIR', './.data'])));

// The base container image used as a fallback when the archive does not exist,
// in a form of `<org>/<repository>` (without a registry prefix).
$image_base = getenv_default(...array_values(array_unique(['VORTEX_FETCH_DB' . $db_index . '_CONTAINER_REGISTRY_IMAGE_BASE', 'VORTEX_DB' . $db_index . '_IMAGE_BASE', 'VORTEX_FETCH_DB_CONTAINER_REGISTRY_IMAGE_BASE', 'VORTEX_DB_IMAGE_BASE', ''])));

// -----------------------------------------------------------------------------

command_must_exist('docker');

/**
 * Whether a container image is present on the host.
 *
 * @param string $image
 *   The image reference to inspect.
 *
 * @return bool
 *   TRUE when the image exists on the host.
 */
function image_exists_on_host(string $image): bool {
  $inspect_result = shell_exec(sprintf('docker image inspect %s >/dev/null 2>&1 && echo 1 || echo 0', escapeshellarg($image)));

  return trim((string) $inspect_result) === '1';
}

INFO('Started database data container image download.');

if (image_exists_on_host($image)) {
  NOTE(sprintf('Found %s image on host.', $image));
}
else {
  NOTE(sprintf('Not found %s image on host.', $image));
}

$image_expanded_successfully = FALSE;
$archive = $db_dir . '/db.tar';

if (file_exists($archive)) {
  // Always use archived image, even if such image already exists on the host.
  $image_expanded_successfully = (bool) TASK(
    sprintf('Found archived database container image file %s. Expanding...', $archive),
    fn(bool $expanded): string => $expanded ? sprintf('Found expanded %s image on host.', $image) : sprintf('Not found expanded %s image on host.', $image),
    function () use ($archive, $image): bool {
      passthru(sprintf('docker load -q --input %s', escapeshellarg($archive)), $exit_code);

      // Check that image was expanded and now exists on the host.
      return image_exists_on_host($image);
    },
  );
}

if (!$image_expanded_successfully) {
  if (!file_exists($archive) && $image_base !== '') {
    // If the image archive does not exist and base image was provided - use the
    // base image which allows "clean slate" for the database.
    NOTE(sprintf('Database container image was not found. Using base image %s.', $image_base));
    $image = $image_base;
  }

  TASK(sprintf('Downloading %s image from the registry.', $image), sprintf('Downloaded %s image from the registry.', $image), function () use ($registry, $registry_user, $registry_pass, $image): void {
    // Login to container registry before pulling.
    putenv('VORTEX_CONTAINER_REGISTRY=' . $registry);
    putenv('VORTEX_CONTAINER_REGISTRY_USER=' . $registry_user);
    putenv('VORTEX_CONTAINER_REGISTRY_PASS=' . $registry_pass);
    passthru_or_fail(__DIR__ . '/vortex-login-container-registry', 'Failed to login to the container registry.');

    passthru_or_fail(sprintf('docker pull %s', escapeshellarg($registry . '/' . $image)), 'Failed to pull image %s from registry.', $image);
  });
}

PASS('Finished database data container image download.');
