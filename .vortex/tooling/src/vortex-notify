#!/usr/bin/env php
<?php

/**
 * @file
 * Notify about events.
 *
 * This is a router script to call relevant scripts based on type.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Notification channels.
//
// Comma-separated values: email,slack,newrelic,github,jira,webhook,diffy.
$channels = getenv_list('VORTEX_NOTIFY_CHANNELS', 'email');

// Notification event type.
//
// Can be 'pre_deployment' or 'post_deployment'.
$event = getenv('VORTEX_NOTIFY_EVENT') ?: 'post_deployment';

// Notification project name.
$project = getenv('VORTEX_NOTIFY_PROJECT') ?: getenv('VORTEX_PROJECT');

// Notification git branch name.
$branch = getenv_required('VORTEX_NOTIFY_BRANCH');

// Notification git commit SHA.
$sha = getenv_required('VORTEX_NOTIFY_SHA');

// Notification pull request number.
$pr_number = getenv_default('VORTEX_NOTIFY_PR_NUMBER', '');

// Notification deployment label (human-readable identifier for display).
$label = getenv_required('VORTEX_NOTIFY_LABEL');

// Notification environment URL (where the site was deployed).
$env_url = getenv_required('VORTEX_NOTIFY_ENVIRONMENT_URL');

// Notification login URL.
$login_url = getenv_default('VORTEX_NOTIFY_LOGIN_URL', $env_url . '/user/login');

// Collect deployment logs into the notification body (0/1). Set in '.env' or
// per environment.
$notify_log = getenv_default('VORTEX_NOTIFY_LOG', '0');

// Directory from which deployment logs are collected. Each producing script
// writes its own '<name>.log' here.
$notify_log_dir = getenv_default('VORTEX_NOTIFY_LOG_DIR', './.logs');

// Notification skip flag.
$skip = getenv('VORTEX_NOTIFY_SKIP');

// -----------------------------------------------------------------------------

INFO('Started dispatching notifications.');

if ($skip) {
  PASS('Skipped dispatching notifications.');
  quit(0);
}

if (empty($channels)) {
  PASS('No notification channels specified, skipping notifications.');
  quit(0);
}

if (!in_array($event, ['pre_deployment', 'post_deployment'], TRUE)) {
  FAIL('Unsupported event %s provided.', $event);
}

// Collect every producer log from the shared directory into one combined file
// for the channels to include, each as its own titled section. Best-effort: a
// failure here must not abort dispatching. The combined file is owner-only, as
// it may aggregate logs containing secrets.
$notify_log_file = '';
if ($notify_log === '1' && is_dir($notify_log_dir)) {
  $combined = $notify_log_dir . '/combined';

  // Only publish the combined file once it has been freshly truncated, so a
  // failed write can never leave a previous run's log to be sent.
  if (@file_put_contents($combined, '') !== FALSE) {
    @chmod($combined, 0600);

    $logs = glob($notify_log_dir . '/*.log') ?: [];
    sort($logs);

    $has_logs = FALSE;
    foreach ($logs as $log) {
      if (!is_file($log) || filesize($log) === 0) {
        continue;
      }

      @file_put_contents($combined, sprintf("## %s ##\n\n%s\n\n", basename($log), (string) file_get_contents($log)), FILE_APPEND);
      $has_logs = TRUE;
    }

    if ($has_logs) {
      $notify_log_file = $combined;
    }
  }
}

// Export variables so notification scripts can use them.
putenv('VORTEX_NOTIFY_BRANCH=' . $branch);
putenv('VORTEX_NOTIFY_SHA=' . $sha);
putenv('VORTEX_NOTIFY_PR_NUMBER=' . $pr_number);
putenv('VORTEX_NOTIFY_LABEL=' . $label);
putenv('VORTEX_NOTIFY_ENVIRONMENT_URL=' . $env_url);
putenv('VORTEX_NOTIFY_LOGIN_URL=' . $login_url);
putenv('VORTEX_NOTIFY_LOG=' . $notify_log);
putenv('VORTEX_NOTIFY_LOG_DIR=' . $notify_log_dir);
putenv('VORTEX_NOTIFY_LOG_FILE=' . $notify_log_file);

INFO('Notification summary:');
NOTE('Project        : %s', $project);
NOTE('Branch         : %s', $branch);
NOTE('SHA            : %s', $sha);
NOTE('PR Number      : %s', ($pr_number ?: '<none>'));
NOTE('Label          : %s', $label);
NOTE('Environment URL: %s', $env_url);
NOTE('Login URL      : %s', $login_url);
if ($notify_log !== '1') {
  NOTE('Log file       : %s', '<disabled>');
}
elseif ($notify_log_file !== '') {
  NOTE('Log file       : %s', $notify_log_file);
}
else {
  NOTE('Log file       : %s', '<missing>');
}
NOTE('Event          : %s', $event);
NOTE('Channels       : %s', implode(',', $channels));

foreach ($channels as $channel) {
  $script = __DIR__ . ('/vortex-notify-' . $channel);

  if (!file_exists($script) || !is_executable($script)) {
    FAIL("Notification script for channel '%s' not found or is not executable: %s", $channel, $script);
  }

  TASK(sprintf('Dispatching notification to the "%s" channel.', $channel), sprintf('Dispatched notification to the "%s" channel.', $channel), function () use ($script, $channel): void {
    $exit_code = 0;
    passthru(sprintf('"%s"', $script), $exit_code);

    if ($exit_code !== 0) {
      throw new \RuntimeException(sprintf('Notification to %s failed with exit code %s', $channel, $exit_code));
    }
  });
}

PASS('Finished dispatching notifications.');
