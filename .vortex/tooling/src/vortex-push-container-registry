#!/usr/bin/env php
<?php

/**
 * @file
 * Push container images to the container registry.
 *
 * Push multiple container images by tagging services provided in the
 * $VORTEX_PUSH_CONTAINER_REGISTRY_MAP variable.
 */

declare(strict_types=1);

namespace DrevOps\VortexTooling;

require_once __DIR__ . '/helpers.php';

// -----------------------------------------------------------------------------

// Container registry URL.
//
// Falls back to VORTEX_CONTAINER_REGISTRY, then defaults to docker.io.
// Examples: docker.io, gcr.io, ghcr.io.
$push_container_registry = getenv_default('VORTEX_PUSH_CONTAINER_REGISTRY', 'VORTEX_CONTAINER_REGISTRY', 'docker.io');

// Container registry username.
//
// Falls back to VORTEX_CONTAINER_REGISTRY_USER.
$push_container_registry_user = getenv_required('VORTEX_PUSH_CONTAINER_REGISTRY_USER', 'VORTEX_CONTAINER_REGISTRY_USER');

// Container registry password.
//
// Falls back to VORTEX_CONTAINER_REGISTRY_PASS.
$push_container_registry_pass = getenv_required('VORTEX_PUSH_CONTAINER_REGISTRY_PASS', 'VORTEX_CONTAINER_REGISTRY_PASS');

// Service to image mapping.
//
// Format: service1=org/image1,service2=org/image2:tag
// Example: web=myorg/myapp,db=myorg/mydb:latest.
$push_container_registry_map = getenv_default('VORTEX_PUSH_CONTAINER_REGISTRY_MAP', '');

// Image tag to use if not specified in the mapping.
$push_container_registry_image_tag = getenv_default('VORTEX_PUSH_CONTAINER_REGISTRY_IMAGE_TAG', 'latest');

// -----------------------------------------------------------------------------

INFO('Started container registry push.');

$push_container_registry_map = string_map_to_array($push_container_registry_map);

// Only push if the map was provided, but do not fail if it has not as this
// may be called as a part of another task.
if (empty($push_container_registry_map)) {
  NOTE('Services map is not specified in VORTEX_PUSH_CONTAINER_REGISTRY_MAP variable. Container registry push will not continue.');
  quit(0);
}

// Export variables and call login script.
putenv('VORTEX_CONTAINER_REGISTRY=' . $push_container_registry);
putenv('VORTEX_CONTAINER_REGISTRY_USER=' . $push_container_registry_user);
putenv('VORTEX_CONTAINER_REGISTRY_PASS=' . $push_container_registry_pass);

// Capture the exit code by reference and quit after the task returns, so the
// task line is closed and the child's exit code is still propagated.
$login_exit_code = 0;
TASK('Logging in to the container registry.', 'Logged in to the container registry.', function () use (&$login_exit_code): void {
  passthru(__DIR__ . '/vortex-login-container-registry', $login_exit_code);
  if ($login_exit_code !== 0) {
    throw new \RuntimeException('Failed to login to the container registry.');
  }
}, fatal: FALSE);

if ($login_exit_code !== 0) {
  quit($login_exit_code);
}

foreach ($push_container_registry_map as $service => $image) {
  $cid = (string) TASK(
    sprintf('Processing service %s.', $service),
    fn(string $cid): string => sprintf('Found "%s" service container with id "%s".', $service, $cid),
    function () use ($service): string {
      // Check if the service is running.
      $cid = shell_exec(sprintf('docker compose ps -q %s', escapeshellarg($service)));
      $cid = $cid !== NULL ? trim((string) $cid) : '';

      if (empty($cid)) {
        throw new \RuntimeException(sprintf('Service "%s" is not running.', $service));
      }

      return $cid;
    },
  );

  // Add tag if not present.
  if (!str_contains($image, ':')) {
    $image .= ':' . $push_container_registry_image_tag;
  }

  $fully_qualified_image_reference = $push_container_registry . '/' . $image;

  TASK(
    sprintf('Committing container image with name "%s".', $fully_qualified_image_reference),
    fn(string $iid): string => sprintf('Committed container image with id "%s".', $iid),
    function () use ($cid, $fully_qualified_image_reference): string {
      $iid = shell_exec(sprintf('docker commit %s %s', escapeshellarg($cid), escapeshellarg($fully_qualified_image_reference)));
      $iid = str_replace('sha256:', '', trim((string) $iid));

      if (empty($iid)) {
        throw new \RuntimeException('Failed to commit container image.');
      }

      return $iid;
    },
  );

  // Capture the exit code by reference and quit after the task returns, so
  // the task line is closed and the child's exit code is still propagated.
  $push_exit_code = 0;
  TASK('Pushing container image to the registry.', 'Pushed container image to the registry.', function () use ($fully_qualified_image_reference, &$push_exit_code): void {
    passthru(sprintf('docker push %s', escapeshellarg($fully_qualified_image_reference)), $push_exit_code);
    if ($push_exit_code !== 0) {
      throw new \RuntimeException('Failed to push container image to the registry.');
    }
  }, fatal: FALSE);

  if ($push_exit_code !== 0) {
    quit($push_exit_code);
  }
}

PASS('Finished container registry push.');
