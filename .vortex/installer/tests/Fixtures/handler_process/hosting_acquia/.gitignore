 # directories that the Drupal core PHPUnit bootstrap requires to exist.
-web/modules/README.txt
-web/profiles/README.txt
-web/sites/README.txt
-web/sites/development.services.yml
-web/themes/README.txt
+docroot/modules/README.txt
+docroot/profiles/README.txt
+docroot/sites/README.txt
+docroot/sites/development.services.yml
+docroot/themes/README.txt
 
 # Local settings overrides.
-web/sites/*/settings.local.php
-web/sites/*/services.local.yml
+docroot/sites/*/settings.local.php
+docroot/sites/*/services.local.yml
 
 # Content files and test artifacts.
-web/sites/*/files
-web/sites/simpletest
+docroot/sites/*/files
+docroot/sites/simpletest
 
 # Composer installs contrib recipes into 'recipes/', next to custom recipes,
 # so recipes stay an allow list: un-ignore custom recipes explicitly.
