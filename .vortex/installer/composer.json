{
    "name": "drevops/vortex-installer",
    "description": "Installer for Vortex.",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "authors": [
        {
            "name": "Alex Skrypnyk",
            "email": "alex@drevops.com",
            "homepage": "https://www.drevops.com",
            "role": "Maintainer"
        }
    ],
    "homepage": "https://github.com/drevops/vortex",
    "support": {
        "issues": "https://github.com/drevops/vortex/issues",
        "source": "https://github.com/drevops/vortex"
    },
    "require": {
        "php": ">=8.2",
        "alexskrypnyk/file": "^0.19.0",
        "alexskrypnyk/str2name": "^1.4.1",
        "composer/composer": "^2.10.1",
        "cweagans/composer-patches": "^2",
        "czproject/git-php": "^4.6",
        "guzzlehttp/guzzle": "^7.12.3",
        "laravel/prompts": "^0.3.21",
        "nelexa/zip": "^4.0.2",
        "nikic/iter": "^2.4.1",
        "sebastian/diff": "^6.0.2",
        "symfony/console": "^7.4.13",
        "symfony/filesystem": "^7.4.11",
        "symfony/yaml": "^7.4.13"
    },
    "require-dev": {
        "alexskrypnyk/phpunit-helpers": "^0.16.0",
        "alexskrypnyk/snapshot": "^1.3.1",
        "bamarni/composer-bin-plugin": "^1.9.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2.1",
        "drevops/phpcs-standard": "^0.6.2",
        "drupal/coder": "^9.0.1@alpha",
        "ergebnis/composer-normalize": "^2.52.0",
        "laravel/serializable-closure": "^2.0.13",
        "mockery/mockery": "^1.6.12",
        "phpstan/phpstan": "^2.2.2",
        "phpunit/phpunit": "^11.5.55",
        "rector/rector": "^2.5.2",
        "symfony/finder": "^7.4.8"
    },
    "autoload": {
        "psr-4": {
            "DrevOps\\VortexInstaller\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DrevOps\\VortexInstaller\\Tests\\": "tests"
        },
        "classmap": [
            "tests"
        ]
    },
    "bin": [
        "installer.php"
    ],
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "bump-after-update": true,
        "process-timeout": 0,
        "sort-packages": true
    },
    "extra": {
        "patches": {
            "laravel/prompts": {
                "Description support, nullable validateUsing, validator precedence, TypedValue truthy check": "patches/laravel-prompts.patch"
            }
        }
    },
    "scripts": {
        "build": [
            "@composer bin box require --dev humbug/box",
            "box validate",
            "box compile"
        ],
        "lint": [
            "phpcs",
            "phpstan",
            "rector --dry-run"
        ],
        "lint-fix": [
            "rector",
            "phpcbf"
        ],
        "reset": "rm -Rf vendor vendor-bin",
        "test": "phpunit --no-coverage",
        "test-coverage": "php -d pcov.directory=. vendor/bin/phpunit",
        "update-snapshots": "update-snapshots --test-dir= testHandlerProcess tests/Fixtures/handler_process $@"
    }
}
