{#
/**
 * @file
 * Footer bottom region.
 *
 * Overrides the base theme region to add a "back to top" link built with the
 * theme's button Single Directory Component, demonstrating real component
 * usage from a template.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 */
#}
{%
  set classes = [
    'region',
    'region--' ~ region|clean_class,
    'grid-full',
    'layout--pass--content-medium',
  ]
%}

{% if content %}
  <div{{ attributes.addClass(classes) }}>
    {{ content }}
    <div class="back-to-top">
      {{ include('your_site_theme:button', { label: 'Back to top'|t, url: '#main-content', modifier: 'secondary' }, with_context = false) }}
    </div>
  </div>
{% endif %}
